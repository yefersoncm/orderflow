# Normalizar finales de línea (evita ruido CRLF/LF entre Windows y Unix)
* text=auto eol=lf

# Scripts de Windows: CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Maven wrapper (shell) y scripts: siempre LF
mvnw text eol=lf
*.sh text eol=lf

# Binarios
*.jar binary
*.png binary
*.jpg binary
*.gif binary
